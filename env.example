# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Site URLs ────────────────────────────────────────────────────────────────
# Production domain (used for SEO canonical tags, OG tags etc.)
NEXT_PUBLIC_SITE_URL=https://www.pattern.lk
# Full base URL of the app — also used as the Gmail OAuth redirect base
NEXT_PUBLIC_APP_URL=https://www.pattern.lk

# ─── Google / Gmail OAuth ────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# OAuth 2.0 Client ID — add  <NEXT_PUBLIC_APP_URL>/api/gmail/callback  as an authorised redirect URI
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Elfsight ────────────────────────────────────────────────────────────────
# Your Elfsight Google Reviews widget App ID (UUID shown in the embed snippet)
NEXT_PUBLIC_ELFSIGHT_GOOGLE_REVIEWS_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Cookie Consent ──────────────────────────────────────────────────────────
# Optional: link to your privacy / cookie policy page
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://www.pattern.lk/privacy
